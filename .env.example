# ============================================================
# Bingo Digital — Variables de Entorno
# ============================================================
#
# Copia este archivo a `.env` y rellena los valores reales:
#   cp .env.example .env
#
# IMPORTANTE:
# - `.env` está en .gitignore. NUNCA lo subas al repo.
# - En Vite, solo las variables con prefijo `VITE_` son accesibles
#   en el código del cliente. El resto solo existe en build-time.
# - En v1 (sin backend), TODAS las variables son `VITE_*` porque
#   solo hay cliente.
# - El DSN de Sentry frontend es PÚBLICO por diseño. No es secreto.
#
# ============================================================


# ---- Sentry ----
# DSN público del proyecto. Lo obtienes al crear el proyecto en sentry.io.
# Si está vacío, Sentry no se inicializa (útil para desarrollo local).
VITE_SENTRY_DSN=


# ---- Entorno de la app ----
# Valores válidos: development | preview | production
# Sentry solo se inicializa cuando este valor NO es 'development'.
# Se establece automáticamente en Vercel según el tipo de deploy.
VITE_APP_ENV=development


# ============================================================
# Variables para CI/CD (NO van en .env local)
# Se configuran en GitHub Secrets:
# ============================================================
#
# SENTRY_AUTH_TOKEN
#   Token con scope `project:releases` para subir sourcemaps en CI.
#   ES SECRETO. Solo en GitHub Secrets, nunca en el repo ni en .env local.
#
# ============================================================
# Variables que llegarán en v2 (Supabase + Culqi)
# Se añadirán cuando arranque v2. No hace falta tenerlas ahora.
# ============================================================
#
# VITE_SUPABASE_URL              (público — URL del proyecto Supabase)
# VITE_SUPABASE_ANON_KEY         (público — anon key, RLS la protege)
# VITE_CULQI_PUBLIC_KEY          (público — public key de Culqi)
#
# SUPABASE_SERVICE_ROLE_KEY      (SECRETO — solo Edge Functions)
# CULQI_PRIVATE_KEY              (SECRETO — solo Edge Functions)
# CULQI_WEBHOOK_SECRET           (SECRETO — verificación HMAC)
#
# ============================================================
